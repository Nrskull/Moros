{
  "name": "morosonder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "deploy": "npm run build && rsync -avz --delete ./dist/ /opt/1panel/apps/openresty/openresty/www/sites/101.132.36.124/index/ && chown -R 1000:1000 /opt/1panel/apps/openresty/openresty/www/sites/101.132.36.124/index",
    "chat": "node server/chat-server.js",
    "chat:lan": "CHAT_HOST=0.0.0.0 node server/chat-server.js",
    "lan": "concurrently -k -n chat,web \"npm:chat:lan\" \"npm:dev:lan\"",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@tiptap/core": "^3.21.0",
    "@tiptap/extension-bubble-menu": "^3.21.0",
    "@tiptap/extension-color": "^3.21.0",
    "@tiptap/extension-highlight": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "ws": "^8.20.0"
  }
